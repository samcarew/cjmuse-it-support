---
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? "YOUR_FORM_ID";
const action = `https://formspree.io/f/${formspreeId}`;
---
<section class="wrap" id="contact">
  <div class="contact">
    <h2>Sick of the spinning wheel?</h2>
    <p class="lead">Let's get it sorted. Fill in the form and I'll get back to you shortly.</p>
    <form action={action} method="POST">
      <div>
        <label for="name">Name</label>
        <input id="name" name="name" type="text" required />
      </div>
      <div>
        <label for="email">Email address</label>
        <input id="email" name="email" type="email" required />
      </div>
      <div>
        <label for="phone">Best phone number</label>
        <input id="phone" name="phone" type="tel" />
      </div>
      <div>
        <label for="message">What's the headache?</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <button type="submit">Send message</button>
    </form>
  </div>
</section>

<style>
  .contact{background:var(--navy);color:#fff;border-radius:var(--radius);padding:48px;margin-top:24px}
  .contact h2{color:#fff}
  .contact p.lead{color:#cfd6e2;font-size:18px;margin-bottom:28px}
  form{display:grid;gap:14px;max-width:560px}
  label{font-size:14px;color:#cfd6e2;font-weight:500}
  input,textarea{
    width:100%;padding:12px 14px;border-radius:8px;
    border:1px solid #2a3a5a;background:#0d1b33;color:#fff;
    font-family:inherit;font-size:15px;
  }
  input:focus,textarea:focus{outline:none;border-color:var(--gold)}
  textarea{min-height:110px;resize:vertical}
  form button{
    background:var(--gold);color:var(--navy);border:none;
    padding:14px 24px;border-radius:10px;font-weight:600;font-size:16px;
    cursor:pointer;margin-top:6px;justify-self:start;transition:background .15s ease;
  }
  form button:hover{background:#e0a647}
  @media (max-width:600px){ .contact{padding:32px 24px} }
</style>
