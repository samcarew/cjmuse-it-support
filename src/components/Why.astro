---
const points = [
  { title: "Zero jargon", body: "I speak human, not \"system architecture.\" You'll always know exactly what I'm doing and what it costs." },
  { title: "Built for solos", body: "I know you don't have a corporate IT budget. My services are priced specifically for freelancers and tradies." },
  { title: "Properly reliable", body: "No overseas call centres. A direct line to a real person in the UK who gets that when your tech is down, you aren't earning." },
];
---
<section class="wrap">
  <h2>Why CJMuse?</h2>
  <div class="why">
    {points.map(p => (
      <div>
        <strong>{p.title}</strong>
        <p>{p.body}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .why{display:grid;gap:24px;grid-template-columns:repeat(auto-fit,minmax(260px,1fr))}
  .why div strong{display:block;color:var(--navy);font-size:17px;margin-bottom:4px}
  .why div p{color:var(--muted);font-size:15px;margin:0}
</style>
