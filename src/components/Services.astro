---
const services = [
  {
    title: "General tech support",
    body: "From printer tantrums to slow Wi-Fi, consider me your on-call IT department. If it's being difficult, I'll get it sorted.",
    icon: "support",
  },
  {
    title: "Email & domain setup",
    body: "Get a proper branded email address that looks the business. I'll handle the setup and make sure your invoices land in customer inboxes.",
    icon: "email",
  },
  {
    title: "Laptop & device security",
    body: "Virus removal, security updates, password vaults and device lockdown. One dodgy email shouldn't be able to sink your whole week.",
    icon: "shield",
  },
  {
    title: "Professional websites",
    body: "Simple, modern sites that actually work on a phone. No hidden monthly fees — just a solid, professional home for your business.",
    icon: "browser",
  },
  {
    title: "Microsoft 365 backup",
    body: "Microsoft doesn't back up your emails, files or contacts for you — if it's deleted, it's gone. I'll set up automatic daily backups so nothing important vanishes.",
    icon: "cloud",
  },
];
---
<section class="wrap">
  <h2>What I fix</h2>
  <div class="grid">
    {services.map(s => (
      <div class="card">
        <div class="icon">
          {s.icon === "support" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 14v-2a8 8 0 0 1 16 0v2" />
              <path d="M20 14v3a2 2 0 0 1-2 2h-1v-6h3z" />
              <path d="M4 14v3a2 2 0 0 0 2 2h1v-6H4z" />
              <path d="M17 19a5 5 0 0 1-5 3" />
            </svg>
          )}
          {s.icon === "email" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="m3 7 9 6 9-6" />
            </svg>
          )}
          {s.icon === "shield" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2 4 5v7c0 4.5 3.5 8.5 8 10 4.5-1.5 8-5.5 8-10V5l-8-3z" />
              <path d="m9 12 2 2 4-4" />
            </svg>
          )}
          {s.icon === "browser" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="16" rx="2" />
              <path d="M3 9h18" />
              <circle cx="6.5" cy="6.5" r="0.6" fill="currentColor" />
              <circle cx="8.8" cy="6.5" r="0.6" fill="currentColor" />
              <circle cx="11.1" cy="6.5" r="0.6" fill="currentColor" />
            </svg>
          )}
          {s.icon === "cloud" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.5 19H7a5 5 0 1 1 .7-9.95A6 6 0 0 1 19 11a4 4 0 0 1-1.5 8z" />
              <path d="M12 12v5" />
              <path d="m9 14 3 3 3-3" />
            </svg>
          )}
        </div>
        <h3>{s.title}</h3>
        <p>{s.body}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .grid{
    display:grid;
    gap:20px;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  }
  .card{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:26px;
  }
  .card p{color:var(--muted);margin:0;font-size:15px}
  .icon{
    width:48px;
    height:48px;
    border-radius:12px;
    background:rgba(201,147,58,0.12);
    color:var(--navy);
    display:flex;
    align-items:center;
    justify-content:center;
    margin-bottom:18px;
  }
  .icon svg{width:26px;height:26px}
</style>
